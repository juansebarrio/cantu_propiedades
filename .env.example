# ════════════════════════════════════════════════════════════
# Cantú Propiedades · variables de entorno
# Copiar a .env.local y completar con valores reales.
# Las credenciales reales viven en 1Password (ver docs/credenciales.md)
# ════════════════════════════════════════════════════════════

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Resend (envío de reportes mensuales)
RESEND_API_KEY=
RESEND_FROM_EMAIL=reportes@cantupropiedades.com.ar
RESEND_REPLY_TO=contacto@cantupropiedades.com.ar

# Cron job (proteger el endpoint del reporte mensual)
CRON_SECRET=

# ────────────────────────────────────────────────────────────
# Feature flags · rollback de mitigaciones del bug de carga
# Dejar sin setear (o vacío) para mantener el fix activo.
# Setear a "true" para volver al comportamiento anterior.
# ────────────────────────────────────────────────────────────

# Si "true", getUsuarioActual() NO se cachea per-render · cada Server
# Component vuelve a pegar a Supabase para validar la sesión.
AUTH_DEDUPE_DISABLED=

# Si "true", el dashboard NO instala el listener de visibilitychange
# que dispara router.refresh() al volver la tab a foreground.
NEXT_PUBLIC_AUTO_REFRESH_DISABLED=
